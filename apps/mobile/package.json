{
  "name": "mobile",
  "version": "0.2.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "doctor": "npx expo-doctor",
    "release:check": "pnpm typecheck && pnpm test && pnpm doctor",
    "build:android:preview": "pnpm exec eas build --platform android --profile preview --non-interactive",
    "build:android:prod": "pnpm exec eas build --platform android --profile production --non-interactive",
    "submit:android:internal": "pnpm exec eas submit --platform android --profile production --non-interactive",
    "submit:android:store": "pnpm exec eas submit --platform android --profile play-store --non-interactive",
    "update:preview": "pnpm exec eas update --channel preview",
    "update:production": "pnpm exec eas update --channel production",
    "eas:init": "pnpm exec eas init && pnpm exec eas update:configure"
  },
  "dependencies": {
    "@chess-school/core": "workspace:*",
    "@chess-school/progression": "workspace:*",
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "ably": "^2.23.0",
    "expo": "~54.0.0",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.0",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.0",
    "expo-updates": "~29.0.18",
    "lottie-react-native": "~7.3.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@vitest/coverage-v8": "^4.1.9",
    "eas-cli": "^20.5.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.9"
  }
}
