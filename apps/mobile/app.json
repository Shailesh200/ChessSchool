{
  "expo": {
    "name": "ChessSchool",
    "slug": "chess-school",
    "version": "0.2.0",
    "description": "A premium chess-learning school — graduate through classes, puzzles, and matches.",
    "orientation": "portrait",
    "scheme": "chessschool",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#fbfaff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chessschool.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.chessschool.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5b5bd6"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#fbfaff",
      "themeColor": "#5b5bd6"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fbfaff",
          "dark": {
            "backgroundColor": "#1c1b2e"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "chess-school-mobile"
      }
    }
  }
}
