{
  "expo": {
    "name": "ChessSchool",
    "slug": "chess-school",
    "version": "0.2.0",
    "description": "A premium chess-learning school — graduate through classes, puzzles, and matches.",
    "orientation": "portrait",
    "scheme": "chessschool",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/af6d1946-9dd2-42ef-b2a3-ad71bfbb7854"
    },
    "newArchEnabled": true,
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#fbfaff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chessschool.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.chessschool.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5b5bd6"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#fbfaff",
      "themeColor": "#5b5bd6"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-audio",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fbfaff",
          "dark": {
            "backgroundColor": "#1c1b2e"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af6d1946-9dd2-42ef-b2a3-ad71bfbb7854"
      }
    },
    "owner": "shaileshjha200"
  }
}
