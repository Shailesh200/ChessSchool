{
  "name": "chess-school",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-db.mjs && next dev",
    "dev:app": "next dev",
    "setup": "node scripts/ensure-db.mjs",
    "build": "next build",
    "start": "node scripts/ensure-db.mjs && next start",
    "start:app": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "screenshots": "node scripts/screenshots.mjs",
    "gen:icons": "node scripts/generate-icons.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node scripts/seed.mjs",
    "db:seed-homework": "node scripts/seed-homework.mjs",
    "db:dump": "node scripts/dump.mjs",
    "db:import-puzzles": "node scripts/import-lichess.mjs",
    "db:reset": "rm -f local.db local.db-shm local.db-wal",
    "db:fresh": "pnpm db:reset && pnpm db:push && pnpm db:seed && pnpm db:seed-homework",
    "db:remote": "node scripts/seed-remote.mjs",
    "db:remote-clean": "node scripts/clean-seed-remote.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "ably": "^2.23.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.0",
    "howler": "^2.2.4",
    "html-to-image": "^1.11.13",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-chessboard": "^5.10.0",
    "react-dom": "19.2.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/howler": "^2.2.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
